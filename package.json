{
  "name": "gemini-gui",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "author": {
    "name": "NishantApps"
  },
  "description": "A GUI to interact with Gemini",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"next dev --turbopack\" \"electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "electron-serve": "^2.1.1",
    "next": "16.1.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
